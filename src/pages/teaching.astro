---
import MainLayout from '../layouts/MainLayout.astro';
import Icon from '../components/Icon.astro';
import { courses } from '../data/content';
---

<MainLayout title="Teaching | Max Hormazábal">
  <div style="padding: 64px 64px 80px; max-width: 720px;">
    <h1 id="teaching-heading" style="font-family: var(--font-display); font-size: 44px; font-weight: 300; letter-spacing: -0.025em; color: var(--ink); margin-bottom: 10px; font-style: italic;">
    </h1>
    <p id="teaching-sub" style="font-family: var(--font-body); font-size: 17px; color: var(--ink-2); line-height: 1.72; margin-bottom: 52px; max-width: 500px;">
    </p>

    {/* Philosophy quote */}
    <section style="margin-bottom: 52px;">
      <div id="philosophy-heading" style="font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 20px;">
      </div>
      <blockquote id="about-quote" style="border-left: 2px solid var(--accent); padding-left: 22px; font-family: var(--font-display); font-style: italic; font-size: 22px; line-height: 1.5; color: var(--ink-2); letter-spacing: -0.01em;">
      </blockquote>
    </section>

    {/* Courses */}
    <section>
      <div id="courses-heading" style="font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 20px;">
      </div>
      <div id="courses-container" style="display: flex; flex-direction: column; gap: 10px;">
        {/* Injected by script to handle language switch of the whole list object */}
      </div>
    </section>
  </div>
</MainLayout>

<script>
  import { T } from '../data/translations';
  import { courses } from '../data/content';

  function updateContent() {
    const lang = localStorage.getItem('mh-lang') || 'en';
    const t = T[lang as keyof typeof T];

    const heading = document.getElementById('teaching-heading');
    if (heading) heading.textContent = t.teaching_heading;
    const sub = document.getElementById('teaching-sub');
    if (sub) sub.textContent = t.teaching_sub;
    const philHeading = document.getElementById('philosophy-heading');
    if (philHeading) philHeading.textContent = t.philosophy_heading;
    const quote = document.getElementById('about-quote');
    if (quote) quote.textContent = t.about_quote;
    const coursesHeading = document.getElementById('courses-heading');
    if (coursesHeading) coursesHeading.textContent = t.courses_heading;

    const container = document.getElementById('courses-container');
    if (container) {
      const groups = courses[lang as keyof typeof courses];
      
      const renderCard = (c: any) => `
        <div style="background: var(--surface-2); border: 1px solid var(--ink-5); border-radius: 4px; padding: 18px 22px; display: flex; gap: 16px; align-items: flex-start;">
          <div style="color: var(--ink-4); padding-top: 2px; flex-shrink: 0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              ${c.icon === 'book' ? '<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>' : 
                c.icon === 'cpu' ? '<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>' :
                c.icon === 'code' ? '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' :
                '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>'
              }
            </svg>
          </div>
          <div style="flex: 1;">
            <div style="font-family: var(--font-display); font-size: 17px; font-weight: 400; color: var(--ink); margin-bottom: 6px; line-height: 1.25;">${c.title}</div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap; align-items: center;">
              <span style="font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-3);">${c.context}</span>
              <span style="font-family: var(--font-mono); font-size: 10.5px; color: var(--ink-4);">${c.years}</span>
              <span style="font-family: var(--font-mono); font-size: 9px; background: var(--surface); border: 1px solid var(--ink-5); border-radius: 2px; padding: 2px 7px; color: var(--ink-4);">${c.level}</span>
            </div>
          </div>
        </div>
      `;

      const t_any = t as any;

      container.innerHTML = `
        <div style="margin-bottom: 24px;">
          <h3 style="font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 12px;">${t_any.section_lectures}</h3>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            ${groups.lectures.map(renderCard).join('')}
          </div>
        </div>
        <div style="margin-bottom: 24px;">
          <h3 style="font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 12px;">${t_any.section_practical}</h3>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            ${groups.practicalSessions.map(renderCard).join('')}
          </div>
        </div>
        <div style="margin-bottom: 24px;">
          <h3 style="font-family: var(--font-mono); font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-3); margin-bottom: 12px;">${t_any.section_assistant}</h3>
          <div style="display: flex; flex-direction: column; gap: 10px;">
            ${groups.teachersAssistant.map(renderCard).join('')}
          </div>
        </div>
      `;
    }
  }

  updateContent();
  window.addEventListener('mh-lang-changed', updateContent);
  document.addEventListener('astro:after-swap', updateContent);
</script>
