---
---
<svg width="180" height="168" viewBox="0 0 268 252" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <style>{`
      @keyframes ilFloat  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
      @keyframes ilFloat2 { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-4px)} }
      @keyframes ilBlink  { 0%,94%,100%{opacity:1} 47%,53%{opacity:0} }
      @keyframes ilPulse  { 0%,100%{opacity:0.25} 50%{opacity:0.85} }
      @keyframes ilSteam  { 0%{opacity:0;transform:translateY(0)} 35%{opacity:0.55} 100%{opacity:0;transform:translateY(-13px)} }
      .il-p1{animation:ilFloat  3.1s ease-in-out infinite;transform-box:fill-box;transform-origin:50% 50%}
      .il-p2{animation:ilFloat2 3.9s ease-in-out infinite 0.6s;transform-box:fill-box;transform-origin:50% 50%}
      .il-blink{animation:ilBlink 1.15s step-end infinite}
      .il-n1{animation:ilPulse 2.4s ease-in-out infinite}
      .il-n2{animation:ilPulse 2.4s ease-in-out infinite 0.8s}
      .il-n3{animation:ilPulse 2.4s ease-in-out infinite 1.6s}
      .il-s1{animation:ilSteam 2.1s ease-out infinite}
      .il-s2{animation:ilSteam 2.1s ease-out infinite 0.7s}
    `}</style>
  </defs>

  {/* Background frame */}
  <rect x="2" y="2" width="264" height="248" rx="10"
    style={{fill:'var(--surface-2)',stroke:'var(--ink-5)',strokeWidth:'1'}}/>

  {/* Neural network — upper right */}
  <line x1="200" y1="30" x2="234" y2="50" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
  <line x1="200" y1="30" x2="218" y2="14" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
  <line x1="234" y1="50" x2="250" y2="34" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
  <line x1="234" y1="50" x2="240" y2="68" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
  <line x1="200" y1="30" x2="240" y2="68" style={{stroke:'var(--ink-5)',strokeWidth:'0.8'}}/>
  <circle cx="200" cy="30" r="5" class="il-n1" style={{fill:'var(--accent)'}}/>
  <circle cx="234" cy="50" r="4" class="il-n2" style={{fill:'var(--interactive)'}}/>
  <circle cx="218" cy="14" r="3" class="il-n3" style={{fill:'var(--ink-4)'}}/>
  <circle cx="250" cy="34" r="3"                   style={{fill:'var(--ink-5)'}}/>
  <circle cx="240" cy="68" r="4" class="il-n1" style={{fill:'var(--accent)'}}/>

  {/* Floating paper 1 — upper left */}
  <g class="il-p1">
    <rect x="16" y="26" width="46" height="58" rx="3"
      style={{fill:'var(--surface)',stroke:'var(--ink-4)',strokeWidth:'1'}}/>
    <line x1="24" y1="39" x2="54" y2="39" style={{stroke:'var(--ink-3)',strokeWidth:'1.5'}}/>
    <line x1="24" y1="47" x2="54" y2="47" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
    <line x1="24" y1="54" x2="48" y2="54" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
    <line x1="24" y1="54" x2="48" y2="54" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
    <line x1="24" y1="61" x2="51" y2="61" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
    <line x1="24" y1="68" x2="42" y2="68" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
  </g>

  {/* Floating paper 2 — right middle */}
  <g class="il-p2">
    <rect x="205" y="86" width="40" height="50" rx="3"
      style={{fill:'var(--surface)',stroke:'var(--ink-4)',strokeWidth:'1',opacity:'0.9'}}/>
    <line x1="213" y1="98"  x2="237" y2="98"  style={{stroke:'var(--ink-4)',strokeWidth:'1.2'}}/>
    <line x1="213" y1="106" x2="237" y2="106" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
    <line x1="213" y1="113" x2="228" y2="113" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
    <line x1="213" y1="120" x2="233" y2="120" style={{stroke:'var(--ink-5)',strokeWidth:'1'}}/>
  </g>

  {/* Head */}
  <ellipse cx="134" cy="76" rx="26" ry="28"
    style={{fill:'var(--surface)',stroke:'var(--ink-3)',strokeWidth:'1.5'}}/>
  {/* Hair */}
  <path d="M112 72 Q114 51 134 49 Q154 47 156 64 Q151 57 134 57 Q118 59 112 72Z"
    style={{fill:'var(--ink-2)'}}/>
  {/* Eyes */}
  <circle cx="126" cy="78" r="2.2" style={{fill:'var(--ink-2)'}}/>
  <circle cx="142" cy="78" r="2.2" style={{fill:'var(--ink-2)'}}/>
  {/* Smile */}
  <path d="M126 89 Q134 95 142 89"
    style={{stroke:'var(--ink-3)',strokeWidth:'1.5',fill:'none',strokeLinecap:'round'}}/>
  {/* Neck */}
  <rect x="128" y="102" width="12" height="13" rx="2"
    style={{fill:'var(--surface)',stroke:'var(--ink-3)',strokeWidth:'1'}}/>

  {/* Body */}
  <path d="M104 188 Q107 124 121 120 L134 116 L147 120 Q161 124 164 188Z"
    style={{fill:'var(--surface-3)',stroke:'var(--ink-3)',strokeWidth:'1.5'}}/>
  {/* Collar detail */}
  <path d="M126 116 L134 126 L142 116"
    style={{stroke:'var(--ink-3)',strokeWidth:'1',fill:'none'}}/>

  {/* Desk */}
  <rect x="14" y="190" width="240" height="9" rx="2"
    style={{fill:'oklch(85% 0.025 74)',stroke:'var(--ink-5)',strokeWidth:'1'}}/>

  {/* Books left */}
  <rect x="22" y="152" width="13" height="38" rx="1" style={{fill:'var(--interactive)',opacity:'0.7'}}/>
  <rect x="37" y="158" width="11" height="32" rx="1" style={{fill:'var(--accent)',opacity:'0.7'}}/>
  <rect x="50" y="164" width="10" height="26" rx="1" style={{fill:'var(--ink-3)',opacity:'0.5'}}/>

  {/* Laptop screen */}
  <rect x="90" y="136" width="126" height="78" rx="4"
    style={{fill:'var(--ink)',opacity:'0.88'}}/>
  <rect x="94" y="140" width="118" height="70" rx="2"
    style={{fill:'var(--code-bg)'}}/>
  <line x1="102" y1="150" x2="162" y2="150" style={{stroke:'var(--accent)',strokeWidth:'1.5',opacity:'0.9'}}/>
  <line x1="102" y1="158" x2="144" y2="158" style={{stroke:'oklch(88% 0.02 75)',strokeWidth:'1',opacity:'0.55'}}/>
  <line x1="102" y1="166" x2="156" y2="166" style={{stroke:'oklch(88% 0.02 75)',strokeWidth:'1',opacity:'0.55'}}/>
  <line x1="102" y1="174" x2="130" y2="174" style={{stroke:'var(--interactive)',strokeWidth:'1',opacity:'0.75'}}/>
  <line x1="102" y1="182" x2="150" y2="182" style={{stroke:'oklch(88% 0.02 75)',strokeWidth:'1',opacity:'0.55'}}/>
  <line x1="102" y1="190" x2="138" y2="190" style={{stroke:'oklch(88% 0.02 75)',strokeWidth:'1',opacity:'0.5'}}/>
  {/* Cursor */}
  <rect x="102" y="198" width="2" height="9" class="il-blink"
    style={{fill:'var(--interactive)'}}/>

  {/* Laptop base */}
  <path d="M84 214 L218 214 L226 222 L76 222Z"
    style={{fill:'var(--ink-2)',opacity:'0.6'}}/>

  {/* Coffee cup */}
  <rect x="232" y="162" width="22" height="26" rx="2"
    style={{fill:'var(--surface)',stroke:'var(--ink-4)',strokeWidth:'1.5'}}/>
  <path d="M254 169 Q262 169 262 175 Q262 181 254 181"
    style={{stroke:'var(--ink-4)',strokeWidth:'1.5',fill:'none'}}/>
  <ellipse cx="243" cy="164" rx="9" ry="2"
    style={{fill:'var(--ink-3)',opacity:'0.4'}}/>
  <path d="M238 160 Q241 153 238 145" class="il-s1"
    style={{stroke:'var(--ink-4)',strokeWidth:'1.2',fill:'none',strokeLinecap:'round'}}/>
  <path d="M245 160 Q248 152 245 143" class="il-s2"
    style={{stroke:'var(--ink-4)',strokeWidth:'1.2',fill:'none',strokeLinecap:'round'}}/>

  {/* Caption */}
  <text x="134" y="244" text-anchor="middle"
    style={{fontFamily:'var(--font-mono)',fontSize:'7.5px',fill:'var(--ink-5)',letterSpacing:'0.08em'}}>
    illustration · placeholder
  </text>
</svg>
