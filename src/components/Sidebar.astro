---
import Icon from './Icon.astro';
import { T } from '../data/translations';

const pathname = new URL(Astro.url).pathname;
const currentPath = pathname === '/' ? 'home' : pathname.replace('/', '');

// In a real i18n setup we would use Astro's middleware or dynamic routes.
// For now, we'll use client-side logic to handle language switching as in the original.
---

<aside class="sidebar">
  {/* Header: name + controls */}
  <div class="sidebar-header-container">
    <div class="brand">
      <a href="/" class="logo-btn">
        <img src="/logo_light.svg" class="logo-light" alt="Logo" width="56" height="56" />
        <img src="/logo_dark.svg" class="logo-dark" alt="Logo" width="56" height="56" />
      </a>
      <a href="/" class="name-link">
        Max<br class="hide-on-mobile" />Hormazábal
      </a>
    </div>
    
    <div class="actions">
      <div class="toggles">
        <button id="theme-toggle" title="Toggle theme" style="background: none; border: 1px solid var(--ink-5); border-radius: 3px; cursor: pointer; color: var(--ink-4); padding: 4px 5px; display: flex; align-items: center; transition: color 0.15s, border-color 0.15s;">
          <Icon name="moon" size={11} class="theme-icon-moon" />
          <Icon name="sun" size={11} class="theme-icon-sun" />
        </button>
        <button id="lang-toggle" title="Toggle language" style="background: none; border: 1px solid var(--ink-5); border-radius: 3px; cursor: pointer; color: var(--ink-4); padding: 3px 5px; font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.06em; transition: color 0.15s, border-color 0.15s;">
          <span class="lang-text">EN</span>
        </button>
      </div>
      
      <button id="menu-toggle" class="show-on-mobile" title="Toggle menu" style="background: none; border: 1px solid var(--ink-5); border-radius: 3px; cursor: pointer; color: var(--ink-4); padding: 4px 5px; display: flex; align-items: center; justify-content: center;">
        <svg class="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="close-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <div class="sidebar-content-wrapper">
    <p class="sidebar-bio">
      {/* Bio injected by JS */}
    </p>

    {/* Navigation */}
    <nav class="sidebar-nav">
      {[
        { id: 'research', icon: 'layers'   },
        { id: 'teaching', icon: 'book-open'},
        { id: 'writing',  icon: 'file-text'},
        { id: 'about',    icon: 'user'     },
      ].map(item => (
        <a href={`/${item.id}`} class={`nav-item ${currentPath === item.id ? 'active' : ''}`} data-id={item.id}>
          <span class="nav-icon">
            <Icon name={item.icon} size={13} />
          </span>
          <span class="nav-label" data-key={item.id}>{item.id}</span>
        </a>
      ))}
    </nav>

    {/* Connect */}
    <div class="sidebar-connect">
      <div class="connect-heading">
        Connect
      </div>
      {[
        { label: 'mhormazabal@dokken.ai', href: 'mailto:mhormazabal@dokken.ai', icon: 'mail' },
        { label: 'github/maxhormazabal',   href: 'https://github.com/maxhormazabal', icon: 'github' },
        { label: 'linkedin',               href: 'https://www.linkedin.com/in/max-hormazabal/', icon: 'linkedin' },
      ].map(item => (
        <a href={item.href} target="_blank" rel="noopener" class="connect-link">
          <Icon name={item.icon} size={11} />
          {item.label}
        </a>
      ))}
    </div>
  </div>
</aside>

<style>
  .sidebar {
    position: fixed; top: 0; left: 0; bottom: 0;
    width: var(--sidebar-w); border-right: 1px solid var(--ink-5);
    display: flex; flex-direction: column;
    background: var(--surface); z-index: 100;
    transition: background 0.2s;
    overflow-y: auto;
  }

  .nav-item {
    color: var(--ink-3);
    background: none;
    border-left: 2px solid transparent;
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    text-align: left;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.01em;
    text-decoration: none;
    padding: 9px 24px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-item.active {
    color: var(--ink);
    background: var(--surface-2);
    border-left: 2px solid var(--accent);
  }
  .nav-item.active .nav-icon {
    color: var(--accent);
  }
  .nav-item:not(.active):hover {
    color: var(--ink-2);
    background: var(--surface-2);
  }
  .logo-btn { margin-left: -10px; }
  .logo-btn:hover { opacity: 0.7; }
  .connect-link:hover { color: var(--ink); }

  .logo-light { display: block; }
  .logo-dark { display: none; }

  :global([data-theme="dark"]) .logo-light { display: none; }
  :global([data-theme="dark"]) .logo-dark { display: block; }

  /* Theme icon visibility */
  :global([data-theme="dark"] .theme-icon-sun) { display: block; }
  :global([data-theme="dark"] .theme-icon-moon) { display: none; }
  :global(:not([data-theme="dark"]) .theme-icon-sun) { display: none; }
  :global(:not([data-theme="dark"]) .theme-icon-moon) { display: block; }

  /* New Styles for Responsive Layout */
  .sidebar-header-container {
    padding: 28px 24px 22px;
    border-bottom: 1px solid var(--ink-5);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  
  .brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .name-link {
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.015em;
    text-decoration: none;
    line-height: 1.1;
  }

  .actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .toggles {
    display: flex;
    gap: 5px;
  }

  .sidebar-bio {
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.65;
    color: var(--ink-2);
    padding: 14px 24px;
  }

  .sidebar-nav {
    padding: 12px 0;
    border-bottom: 1px solid var(--ink-5);
  }

  .sidebar-connect {
    padding: 20px 24px;
  }

  .connect-heading {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-4);
    margin-bottom: 14px;
  }

  .connect-link {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--ink-3);
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    padding: 5px 0;
    transition: color 0.15s;
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100% !important;
      height: auto !important;
      position: sticky !important;
      top: 0;
      border-right: none !important;
      border-bottom: 1px solid var(--ink-5);
      z-index: 200 !important;
    }

    .sidebar-header-container {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      border-bottom: none;
    }

    .brand {
      flex-direction: row;
      align-items: center;
      gap: 10px;
    }

    .name-link {
      font-size: 18px;
      line-height: 1;
      transform: translateY(2px);
    }

    .logo-btn {
      margin-left: 0;
      display: flex;
      align-items: center;
    }

    .logo-btn img {
      width: 36px;
      height: 36px;
    }

    .actions {
      gap: 10px;
    }

    .sidebar-content-wrapper {
      display: none;
      position: fixed;
      top: 61px;
      left: 0;
      width: 100%;
      height: calc(100vh - 61px);
      background: var(--surface);
      z-index: 199;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      padding: 40px;
    }

    :global(body.menu-open) .sidebar-content-wrapper {
      display: flex;
    }

    .sidebar-nav {
      border-bottom: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }

    .nav-item {
      font-size: 20px;
      padding: 10px;
      justify-content: center;
      border-left: none;
    }

    .nav-item.active {
      background: none;
      border-bottom: 2px solid var(--accent);
    }

    .sidebar-bio, .sidebar-connect {
      display: none;
    }

    :global([data-theme="dark"]) .nav-item:not(.active) {
      color: var(--ink-2) !important;
    }
  }

  :global([data-theme="dark"]) #theme-toggle,
  :global([data-theme="dark"]) #lang-toggle {
    color: var(--ink-3) !important;
    border-color: var(--ink-4) !important;
  }
</style>

<script>
  import { T } from '../data/translations';

  function updateSidebar() {
    const lang = localStorage.getItem('mh-lang') || 'en';
    const t = T[lang as keyof typeof T];

    // Update labels
    document.querySelectorAll('.nav-label').forEach(el => {
      const key = el.getAttribute('data-key');
      if (key && t.nav[key as keyof typeof t.nav]) {
        el.textContent = t.nav[key as keyof typeof t.nav];
      }
    });

    const bioEl = document.querySelector('.sidebar-bio');
    if (bioEl) bioEl.textContent = t.sidebar_bio;

    const connectHeading = document.querySelector('.connect-heading');
    if (connectHeading) connectHeading.textContent = t.connect_heading;

    const langBtnText = document.querySelector('.lang-text');
    if (langBtnText) langBtnText.textContent = lang === 'en' ? 'ES' : 'EN';
  }

  // Initial update
  updateSidebar();

  // Listeners
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const next = !isDark;
    document.documentElement.setAttribute('data-theme', next ? 'dark' : '');
    localStorage.setItem('mh-dark', String(next));
  });

  document.getElementById('lang-toggle')?.addEventListener('click', () => {
    const current = localStorage.getItem('mh-lang') || 'en';
    const next = current === 'en' ? 'es' : 'en';
    localStorage.setItem('mh-lang', next);
    updateSidebar();
    // Dispatch event for other components
    window.dispatchEvent(new CustomEvent('mh-lang-changed', { detail: { lang: next } }));
  });

  // Mobile Menu Toggle
  const menuToggle = document.getElementById('menu-toggle');
  const hamburgerIcon = document.querySelector('.hamburger-icon') as HTMLElement;
  const closeIcon = document.querySelector('.close-icon') as HTMLElement;

  menuToggle?.addEventListener('click', () => {
    const isOpen = document.body.classList.toggle('menu-open');
    if (hamburgerIcon && closeIcon) {
      hamburgerIcon.style.display = isOpen ? 'none' : 'block';
      closeIcon.style.display = isOpen ? 'block' : 'none';
    }
  });

  // Close menu when clicking a link
  document.querySelectorAll('.nav-item').forEach(link => {
    link.addEventListener('click', () => {
      document.body.classList.remove('menu-open');
      if (hamburgerIcon && closeIcon) {
        hamburgerIcon.style.display = 'block';
        closeIcon.style.display = 'none';
      }
    });
  });

  // Re-run on ViewTransitions
  document.addEventListener('astro:after-swap', updateSidebar);
</script>
